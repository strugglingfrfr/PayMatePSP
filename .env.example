# PayMate environment variables — copy to .env (never commit .env)

# AWS
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=         # Bedrock long-term API key

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR_PATH=~/.config/solana/paymate-dev.json

# Base (x402 agent)
BASE_RPC_URL=https://sepolia.base.org
BASE_PRIVATE_KEY=                 # private key of agent wallet on Base Sepolia

# Coinbase Developer Platform (x402 Facilitator)
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=

# Mobile (Expo)
EXPO_PUBLIC_API_URL=               # API Gateway URL after Lambda deploy
EXPO_PUBLIC_PROGRAM_ID=            # Anchor program ID after deploy
EXPO_PUBLIC_USDC_MINT=             # devnet USDC mint

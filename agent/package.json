{
  "name": "paymate-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:risk": "esbuild src/risk/index.ts --bundle --platform=node --target=node20 --outfile=dist/risk/index.js --minify",
    "build:compliance": "esbuild src/compliance/index.ts --bundle --platform=node --target=node20 --outfile=dist/compliance/index.js --minify",
    "build": "bun run build:risk && bun run build:compliance",
    "package": "bun run build && rm -f dist/risk.zip dist/compliance.zip && cd dist/risk && zip -q ../risk.zip index.js && cd ../compliance && zip -q ../compliance.zip index.js && cd ../..",
    "deploy": "bun run package && bash infra/deploy.sh"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@noble/hashes": "^1.6.0",
    "@x402/core": "^2.11.0",
    "@x402/evm": "^2.11.0",
    "@x402/fetch": "^2.11.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}

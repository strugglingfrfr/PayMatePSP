{
  "name": "paymate-lambda",
  "version": "0.1.0",
  "private": true,
  "description": "PayMate Lambda orchestrator — mobile-facing API. Routes KYB submissions to the x402 risk agent and reads Solana pool state.",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@aws-sdk/* --minify",
    "package": "bun run build && cd dist && zip -q -r ../lambda.zip . && cd ..",
    "deploy": "bun run package && bash infra/deploy.sh",
    "teardown": "bash infra/teardown.sh",
    "test": "bun test"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^6.0.0",
    "viem": "^2.48.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
